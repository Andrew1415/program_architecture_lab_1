{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:8088/books"
      ],
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.7
          }
        ],
        "largest-contentful-paint": [
          "warn",
          {
            "maxNumericValue": 2500
          }
        ],
        "total-blocking-time": [
          "warn",
          {
            "maxNumericValue": 200
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
